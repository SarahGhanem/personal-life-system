# Local dev (docker-compose) or your Neon/Supabase connection strings.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/personal_life_system?schema=public"
# For Neon/Supabase in production, DATABASE_URL should be the pooled (pgbouncer) endpoint
# and DIRECT_URL the unpooled endpoint used only for migrations.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/personal_life_system?schema=public"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:3000"
